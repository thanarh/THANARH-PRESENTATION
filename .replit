modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
MONGODB_DATABASE_NAME = "thanarah_presentation"
NODE_ENV = "development"
SMTP2GO_HOST = "mail.smtp2go.com"
SMTP2GO_PORT = "587"
SMTP_FROM_EMAIL = "noreply@thanarh.com"
SMTP_FROM_NAME = "نظام ثناره الطبي"
THANARAH_OWNER_EMAIL_1 = "youssefd.business@gmail.com"
THANARAH_OWNER_EMAIL_2 = "faisal.m.alenzai@gmail.com"

modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Thanarah Portal"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Thanarah Portal"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3000 BASE_PATH=/ pnpm --filter @workspace/thanarah-portal run dev"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
MONGODB_DATABASE_NAME = "thanarah_presentation"
NODE_ENV = "development"
SMTP2GO_HOST = "mail.smtp2go.com"
SMTP2GO_PORT = "587"
SMTP_FROM_EMAIL = "noreply@thanarh.com"
SMTP_FROM_NAME = "نظام ثناره الطبي"
THANARAH_OWNER_EMAIL_1 = "youssefd.business@gmail.com"
THANARAH_OWNER_EMAIL_2 = "faisal.m.alenzai@gmail.com"

[nix]
channel = "stable-25_05"
